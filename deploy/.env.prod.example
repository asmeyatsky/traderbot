# ============================================================================
# TraderBot Production Environment — EC2 t4g.small
# ============================================================================
# Copy to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod && nano .env.prod
#
# NEVER commit .env.prod to git.

# ── Domain (REQUIRED) ────────────────────────────────────────────────
# Point this domain's DNS A record to your Elastic IP
DOMAIN=traderbot.example.com

# ── Database (REQUIRED) ──────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32
POSTGRES_DB=traderbot

# ── Security (REQUIRED) ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# ── AI Chat (Required for chat feature) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CHAT_MODEL=claude-sonnet-4-20250514

# ── Market Data APIs (fill in what you use) ──────────────────────────
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# ── Broker (Alpaca) ──────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
