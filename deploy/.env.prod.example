# ============================================================================
# TraderBot Production Environment — EC2 t4g.medium
# ============================================================================
# Copy to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod && nano .env.prod
#
# NEVER commit .env.prod to git.

# ── Domain (REQUIRED) ────────────────────────────────────────────────
# Point this domain's DNS A record to your Elastic IP
DOMAIN=traderbot.example.com

# ── Database (REQUIRED) ──────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_base64_32
POSTGRES_DB=traderbot

# ── Security (REQUIRED) ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# ── AI Chat (Required for chat feature) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CHAT_MODEL=claude-sonnet-4-20250514

# ── Market Data APIs (fill in what you use) ──────────────────────────
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# ── Broker (Alpaca) ──────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Secrets handling (Phase 3 boot guard) ────────────────────────────
# The app refuses to boot in production unless EITHER:
#   (a) AWS_SECRETS_NAME is set and the container has IAM access to pull,
#   OR
#   (b) ALLOW_ENV_SECRETS=true (transitional — env-based secrets are the
#       legacy path; migrate to AWS Secrets Manager when ready).
# Until the AWS Secrets Manager migration is done, keep the opt-out flag.
ALLOW_ENV_SECRETS=true
# AWS_SECRETS_NAME=traderbot/prod
# AWS_REGION=eu-west-2

# ── Live trading kill switches (ADR-002) ─────────────────────────────
# EMERGENCY_HALT — platform-wide stop. When 'true', every user is forced
# to paper mode regardless of their trading_mode. Flip to 'true' and
# `bash deploy.sh restart` to halt real-money trading NOW.
EMERGENCY_HALT=false
# ENABLE_LIVE_TRADING — feature flag. When 'false' or unset, LIVE-mode
# users still get paper. Flip to 'true' only after the Phase 8 launch
# gate (staging soak + beta whitelist) is met.
ENABLE_LIVE_TRADING=false
